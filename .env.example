# =============================================
# Mi Familia - Configuración
# Copia este archivo a .env y rellena los valores
# =============================================

PORT=3000
TIMEZONE=Europe/Madrid

# Auth (requerido)
JWT_SECRET=cambia_esto_por_una_cadena_aleatoria_larga
ADMIN_EMAIL=admin@familia.local
ADMIN_PASSWORD=admin1234
APP_URL=http://localhost:3000

# Telegram global (opcional — se configura también por usuario desde el perfil)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID_1=
TELEGRAM_CHAT_ID_2=

# Email para recuperación de contraseña (opcional)
# Sin esto, el enlace de reset aparece en la consola del servidor
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@familia.app
